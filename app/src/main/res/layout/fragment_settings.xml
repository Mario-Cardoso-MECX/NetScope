<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONFIGURACIÓN"
            android:textColor="@color/neon_accent"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="24dp"/>

        <!-- SECCIÓN: PREFERENCIAS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PREFERENCIAS"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <!-- Switch 1: Notificaciones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/card_background"
            android:padding="16dp"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Alertas de Amenazas" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Notificaciones push de intrusos" android:textColor="@color/text_secondary" android:textSize="12sp"/>
            </LinearLayout>
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchThreats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                app:useMaterialThemeColors="true"/>
        </LinearLayout>

        <!-- Switch 2: Auto Escaneo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/card_background"
            android:padding="16dp"
            android:layout_marginBottom="24dp"
            android:gravity="center_vertical">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Auto-Escaneo" android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Escaneo en segundo plano (30 min)" android:textColor="@color/text_secondary" android:textSize="12sp"/>
            </LinearLayout>
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchAutoScan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:useMaterialThemeColors="true"/>
        </LinearLayout>

        <!-- SECCIÓN: ACERCA DE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACERCA DE"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/card_background"
            android:padding="16dp"
            android:layout_marginBottom="24dp">
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Versión" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2.4.1" android:textColor="@color/neon_accent" android:textSize="14sp" android:layout_alignParentRight="true"/>
            </RelativeLayout>
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Build" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="20260721" android:textColor="@color/text_secondary" android:textSize="14sp" android:layout_alignParentRight="true"/>
            </RelativeLayout>
        </LinearLayout>

        <!-- BOTÓN EXPORTAR REPORTES -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExportReport"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="EXPORTAR REPORTE DE RED"
            android:backgroundTint="@color/neon_accent"
            android:textColor="@color/primary_background"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            app:icon="@android:drawable/ic_menu_share"
            app:iconTint="@color/primary_background"
            app:iconGravity="textStart"/>

    </LinearLayout>
</ScrollView>