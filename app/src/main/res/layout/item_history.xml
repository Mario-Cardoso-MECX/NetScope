<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@color/card_background"
    android:padding="16dp"
    android:layout_marginBottom="12dp"
    android:gravity="center_vertical">

    <!-- Lado Izquierdo: Red y Fecha -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvHistorySubnet"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="192.168.1.0/24"
            android:textColor="@color/neon_accent"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="monospace"/>

        <TextView
            android:id="@+id/tvHistoryDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hoy 14:31"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Lado Derecho: Contadores y Estado -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/tvHistoryHosts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="6 equipos"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvHistoryThreats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 amenaza"
            android:textColor="@color/danger_red"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

</LinearLayout>