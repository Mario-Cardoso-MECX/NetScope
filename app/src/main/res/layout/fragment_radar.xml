<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary_background"
    android:padding="24dp">

    <!-- EL NOMBRE DEL PROYECTO -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/neon_accent"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/radar_title"
        android:textColor="@color/text_primary"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <!-- EL ESCÁNER VISUAL TIPO PELÍCULA -->
    <FrameLayout
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_gravity="center"
        android:layout_marginBottom="32dp">

        <!-- 1. Cuadrícula de radar estática -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/radar_grid" />

        <!-- 2. Capa invisible donde inyectaremos los puntitos dinámicamente -->
        <FrameLayout
            android:id="@+id/dotsContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- 3. El Haz de luz que SÍ va a girar por encima de los puntos -->
        <ImageView
            android:id="@+id/ivRadarSweep"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/radar_sweep"
            android:visibility="invisible"/>
    </FrameLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartScan"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/btn_start_scan"
        android:backgroundTint="@color/neon_accent"
        android:textColor="@color/primary_background"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        app:cornerRadius="8dp"/>

    <!-- EL CONTADOR DINÁMICO (Inyectamos el ID aquí) -->
    <TextView
        android:id="@+id/tvDeviceCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0 dispositivos detectados"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerDevices"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>