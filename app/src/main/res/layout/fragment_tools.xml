<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary_background"
    android:padding="24dp">

    <!-- Título de la Pantalla -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/nav_tools"
        android:textColor="@color/neon_accent"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="16dp"/>

    <!-- Entrada Maestra Única -->
    <EditText
        android:id="@+id/etTarget"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Objetivo (ej. 192.168.1.1 o google.com)"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:background="@color/card_background"
        android:padding="16dp"
        android:layout_marginBottom="16dp"
        android:inputType="textUri"/>

    <!-- Cuadrícula de Herramientas (Grid) -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        android:alignmentMode="alignBounds">

        <!-- Tarjeta 1: DNS -->
        <LinearLayout
            android:id="@+id/btnDnsLookup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:background="@color/card_background"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp">
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="@color/neon_accent" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="RESOLUCIÓN DNS"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Tarjeta 2: PING -->
        <LinearLayout
            android:id="@+id/btnPing"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:background="@color/card_background"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp">
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="@color/neon_accent" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="PING MANUAL"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Tarjeta 3: WHOIS -->
        <LinearLayout
            android:id="@+id/btnWhois"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:background="@color/card_background"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp"
            android:alpha="0.5">
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_info_details"
                app:tint="@color/text_secondary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="WHOIS"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Tarjeta 4: TRACEROUTE -->
        <LinearLayout
            android:id="@+id/btnTraceroute"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:background="@color/card_background"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp"
            android:alpha="0.5">
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_share"
                app:tint="@color/text_secondary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="TRACEROUTE"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </GridLayout>

    <!-- Consola de Resultados -->
    <TextView
        android:id="@+id/tvResult"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="16dp"
        android:text="> Consola en espera...\n> Ingresa un objetivo y selecciona una herramienta."
        android:textColor="@color/neon_accent"
        android:fontFamily="monospace"
        android:padding="16dp"
        android:background="@color/card_background"
        android:gravity="top|start"/>

</LinearLayout>