<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_tools"
            android:textColor="#00FF7F"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/etTarget"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="ej. google.com"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:background="#161B22"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnDnsLookup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DNS LOOKUP"
            android:backgroundTint="#00FF7F"
            android:textColor="#0D1117"
            android:layout_marginBottom="32dp"/>

        <EditText
            android:id="@+id/etPingTarget"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="ej. 192.168.1.1"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:background="#161B22"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnPing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EJECUTAR PING"
            android:backgroundTint="#00FF7F"
            android:textColor="#0D1117"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Los resultados aparecerán aquí..."
            android:textColor="#888888"
            android:fontFamily="monospace"
            android:padding="16dp"
            android:background="#0D1117"/>
    </LinearLayout>
</ScrollView>