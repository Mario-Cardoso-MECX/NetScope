<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary_background"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SECURITY TOOLS"
        android:textColor="@color/neon_accent"
        android:textSize="14sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etTarget"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Objetivo (ej. 192.168.1.1 o google.com)"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:background="@color/card_background"
        android:padding="16dp"
        android:layout_marginBottom="16dp"
        android:inputType="textUri"/>

    <!-- Cuadrícula de 6 Herramientas con MaterialCardView -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="3"
        android:alignmentMode="alignBounds">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="16dp"
            app:strokeColor="#2000FF00"
            app:strokeWidth="1dp">
            <LinearLayout android:id="@+id/btnPortScanner" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="16dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_search" app:tint="@color/neon_accent" android:layout_marginBottom="8dp"/>
                    <ImageView android:id="@+id/infoPortScanner" android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_menu_help" app:tint="@color/text_secondary" android:layout_alignParentEnd="true"/>
                </RelativeLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Port Scanner" android:textColor="@color/neon_accent" android:textSize="14sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TCP/UDP port sweep" android:textColor="@color/text_secondary" android:textSize="11sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="16dp"
            app:strokeColor="#2000FF00"
            app:strokeWidth="1dp">
            <LinearLayout android:id="@+id/btnPing" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="16dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_mylocation" app:tint="@color/neon_accent" android:layout_marginBottom="8dp"/>
                    <ImageView android:id="@+id/infoPing" android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_menu_help" app:tint="@color/text_secondary" android:layout_alignParentEnd="true"/>
                </RelativeLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ping Sweep" android:textColor="@color/neon_accent" android:textSize="14sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ICMP host discovery" android:textColor="@color/text_secondary" android:textSize="11sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="16dp"
            app:strokeColor="#2000FF00"
            app:strokeWidth="1dp">
            <LinearLayout android:id="@+id/btnDnsLookup" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="16dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_sort_by_size" app:tint="@color/neon_accent" android:layout_marginBottom="8dp"/>
                    <ImageView android:id="@+id/infoDns" android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_menu_help" app:tint="@color/text_secondary" android:layout_alignParentEnd="true"/>
                </RelativeLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DNS Lookup" android:textColor="@color/neon_accent" android:textSize="14sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Resolve hostnames" android:textColor="@color/text_secondary" android:textSize="11sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="16dp"
            app:strokeColor="#2000FF00"
            app:strokeWidth="1dp">
            <LinearLayout android:id="@+id/btnTraceroute" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="16dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_mapmode" app:tint="@color/neon_accent" android:layout_marginBottom="8dp"/>
                    <ImageView android:id="@+id/infoTraceroute" android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_menu_help" app:tint="@color/text_secondary" android:layout_alignParentEnd="true"/>
                </RelativeLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Traceroute" android:textColor="@color/neon_accent" android:textSize="14sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hop path analysis" android:textColor="@color/text_secondary" android:textSize="11sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="16dp"
            app:strokeColor="#2000FF00"
            app:strokeWidth="1dp">
            <LinearLayout android:id="@+id/btnWhois" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="16dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_agenda" app:tint="@color/neon_accent" android:layout_marginBottom="8dp"/>
                    <ImageView android:id="@+id/infoWhois" android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_menu_help" app:tint="@color/text_secondary" android:layout_alignParentEnd="true"/>
                </RelativeLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Whois" android:textColor="@color/neon_accent" android:textSize="14sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Domain registration" android:textColor="@color/text_secondary" android:textSize="11sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="16dp"
            app:strokeColor="#2000FF00"
            app:strokeWidth="1dp">
            <LinearLayout android:id="@+id/btnSsl" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="16dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_secure" app:tint="@color/neon_accent" android:layout_marginBottom="8dp"/>
                    <ImageView android:id="@+id/infoSsl" android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_menu_help" app:tint="@color/text_secondary" android:layout_alignParentEnd="true"/>
                </RelativeLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SSL Inspector" android:textColor="@color/neon_accent" android:textSize="14sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Certificate details" android:textColor="@color/text_secondary" android:textSize="11sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </GridLayout>

    <TextView
        android:id="@+id/tvResult"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="16dp"
        android:text="> Consola en espera...\n> Ingresa un objetivo y selecciona una herramienta.\n> (Mantén presionado aquí para copiar el resultado)"
        android:textColor="@color/neon_accent"
        android:fontFamily="monospace"
        android:padding="16dp"
        android:background="@color/card_background"
        android:gravity="top|start"
        android:textIsSelectable="true"/>
</LinearLayout>