<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary_background"
    android:padding="24dp">

    <!-- Título de la Pantalla -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HERRAMIENTAS DE SEGURIDAD"
        android:textColor="@color/neon_accent"
        android:textSize="14sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="16dp"/>

    <!-- Entrada Maestra Única -->
    <EditText
        android:id="@+id/etTarget"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Objetivo (ej. 192.168.1.1 o google.com)"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_secondary"
        android:background="@color/card_background"
        android:padding="16dp"
        android:layout_marginBottom="16dp"
        android:inputType="textUri"/>

    <!-- Cuadrícula de 6 Herramientas (Grid) -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="3"
        android:alignmentMode="alignBounds">

        <!-- 1: Escáner de Puertos -->
        <LinearLayout
            android:id="@+id/btnPortScanner"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:background="@color/card_background"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="12dp">
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Escáner de Puertos" android:textColor="@color/neon_accent" android:textSize="13sp" android:textStyle="bold" android:layout_alignParentStart="true"/>
                <ImageView android:id="@+id/infoPortScanner" android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_menu_help" app:tint="@color/text_secondary" android:layout_alignParentEnd="true"/>
            </RelativeLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Barrido TCP/UDP" android:textColor="@color/text_secondary" android:textSize="11sp" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- 2: Barrido Ping -->
        <LinearLayout
            android:id="@+id/btnPing"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:background="@color/card_background"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="12dp">
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Barrido Ping" android:textColor="@color/neon_accent" android:textSize="13sp" android:textStyle="bold" android:layout_alignParentStart="true"/>
                <ImageView android:id="@+id/infoPing" android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_menu_help" app:tint="@color/text_secondary" android:layout_alignParentEnd="true"/>
            </RelativeLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Descubrimiento ICMP" android:textColor="@color/text_secondary" android:textSize="11sp" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- 3: Búsqueda DNS -->
        <LinearLayout
            android:id="@+id/btnDnsLookup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:background="@color/card_background"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="12dp">
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Búsqueda DNS" android:textColor="@color/neon_accent" android:textSize="13sp" android:textStyle="bold" android:layout_alignParentStart="true"/>
                <ImageView android:id="@+id/infoDns" android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_menu_help" app:tint="@color/text_secondary" android:layout_alignParentEnd="true"/>
            </RelativeLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Resolución de nombres" android:textColor="@color/text_secondary" android:textSize="11sp" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- 4: Traceroute -->
        <LinearLayout
            android:id="@+id/btnTraceroute"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:background="@color/card_background"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="12dp">
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Traceroute" android:textColor="@color/neon_accent" android:textSize="13sp" android:textStyle="bold" android:layout_alignParentStart="true"/>
                <ImageView android:id="@+id/infoTraceroute" android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_menu_help" app:tint="@color/text_secondary" android:layout_alignParentEnd="true"/>
            </RelativeLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Análisis de saltos" android:textColor="@color/text_secondary" android:textSize="11sp" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- 5: Whois -->
        <LinearLayout
            android:id="@+id/btnWhois"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:background="@color/card_background"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="12dp">
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Whois" android:textColor="@color/neon_accent" android:textSize="13sp" android:textStyle="bold" android:layout_alignParentStart="true"/>
                <ImageView android:id="@+id/infoWhois" android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_menu_help" app:tint="@color/text_secondary" android:layout_alignParentEnd="true"/>
            </RelativeLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Registro de dominio" android:textColor="@color/text_secondary" android:textSize="11sp" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- 6: Inspector SSL -->
        <LinearLayout
            android:id="@+id/btnSsl"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="6dp"
            android:background="@color/card_background"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="12dp">
            <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Inspector SSL" android:textColor="@color/neon_accent" android:textSize="13sp" android:textStyle="bold" android:layout_alignParentStart="true"/>
                <ImageView android:id="@+id/infoSsl" android:layout_width="18dp" android:layout_height="18dp" android:src="@android:drawable/ic_menu_help" app:tint="@color/text_secondary" android:layout_alignParentEnd="true"/>
            </RelativeLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Detalles de certificado" android:textColor="@color/text_secondary" android:textSize="11sp" android:layout_marginTop="2dp"/>
        </LinearLayout>
    </GridLayout>

    <!-- Consola de Resultados -->
    <TextView
        android:id="@+id/tvResult"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="16dp"
        android:text="> Consola en espera...\n> Ingresa un objetivo y selecciona una herramienta.\n> (Mantén presionado aquí para copiar el resultado)"
        android:textColor="@color/neon_accent"
        android:fontFamily="monospace"
        android:padding="16dp"
        android:background="@color/card_background"
        android:gravity="top|start"
        android:textIsSelectable="true"/>
</LinearLayout>