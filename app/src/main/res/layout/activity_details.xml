<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1117"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvDetailName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Target Name"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvDetailIp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="192.168.1.X"
        android:textColor="#00FF7F"
        android:textSize="18sp"
        android:layout_marginBottom="32dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAudit"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:text="AUDITAR PUERTOS TCP"
        android:textColor="#0D1117"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="#00FF7F"
        app:cornerRadius="12dp"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="RESULTADOS DEL ESCANEO"
        android:textColor="#888888"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#161B22"
        android:padding="16dp"
        android:orientation="vertical">

        <TextView android:id="@+id/port21" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="[ 21 ] FTP - Esperando..." android:textColor="#888888" android:paddingVertical="8dp"/>
        <TextView android:id="@+id/port22" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="[ 22 ] SSH - Esperando..." android:textColor="#888888" android:paddingVertical="8dp"/>
        <TextView android:id="@+id/port80" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="[ 80 ] HTTP - Esperando..." android:textColor="#888888" android:paddingVertical="8dp"/>
        <TextView android:id="@+id/port443" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="[ 443 ] HTTPS - Esperando..." android:textColor="#888888" android:paddingVertical="8dp"/>
        <TextView android:id="@+id/port3306" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="[ 3306 ] MySQL - Esperando..." android:textColor="#888888" android:paddingVertical="8dp"/>
        <TextView android:id="@+id/port3389" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="[ 3389 ] RDP - Esperando..." android:textColor="#888888" android:paddingVertical="8dp"/>

    </LinearLayout>
</LinearLayout>