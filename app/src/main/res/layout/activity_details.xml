<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary_background"
    android:padding="24dp">

    <!-- Cabecera del Objetivo -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AUDITORÍA DE OBJETIVO"
        android:textColor="@color/neon_accent"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"/>

    <TextView
        android:id="@+id/tvTargetName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cargando..."
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/tvTargetIp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0.0.0.0"
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="24dp"/>

    <!-- Título de Puertos -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ESTADO DE PUERTOS TCP"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <!-- Cuadrícula de Puertos -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="2"
        android:alignmentMode="alignBounds"
        android:layout_marginBottom="16dp">

        <TextView android:id="@+id/port21" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="4dp" android:background="@color/card_background" android:text="21 FTP" android:textColor="@color/text_secondary" android:textAlignment="center" android:padding="12dp" android:textStyle="bold"/>
        <TextView android:id="@+id/port22" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="4dp" android:background="@color/card_background" android:text="22 SSH" android:textColor="@color/text_secondary" android:textAlignment="center" android:padding="12dp" android:textStyle="bold"/>
        <TextView android:id="@+id/port80" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="4dp" android:background="@color/card_background" android:text="80 HTTP" android:textColor="@color/text_secondary" android:textAlignment="center" android:padding="12dp" android:textStyle="bold"/>
        <TextView android:id="@+id/port443" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="4dp" android:background="@color/card_background" android:text="443 HTTPS" android:textColor="@color/text_secondary" android:textAlignment="center" android:padding="12dp" android:textStyle="bold"/>
        <TextView android:id="@+id/port3306" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="4dp" android:background="@color/card_background" android:text="3306 MySQL" android:textColor="@color/text_secondary" android:textAlignment="center" android:padding="12dp" android:textStyle="bold"/>
        <TextView android:id="@+id/port3389" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_margin="4dp" android:background="@color/card_background" android:text="3389 RDP" android:textColor="@color/text_secondary" android:textAlignment="center" android:padding="12dp" android:textStyle="bold"/>

    </GridLayout>

    <!-- Botón de Análisis CVE -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVulnScan"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="16dp"
        android:text="ANÁLISIS DE VULNERABILIDADES (CVE)"
        android:backgroundTint="#D32F2F"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:cornerRadius="8dp" />

    <!-- Título Consola -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CONSOLA DE BANNER GRABBING"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <!-- Consola de Resultados -->
    <ScrollView
        android:id="@+id/scrollViewConsole"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/card_background"
        android:padding="12dp">
        <TextView
            android:id="@+id/tvConsole"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="> Iniciando auditoría ofensiva...\n"
            android:textColor="@color/neon_accent"
            android:fontFamily="monospace"
            android:textSize="12sp"/>
    </ScrollView>

</LinearLayout>